<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <Nullable>disable</Nullable>
    <RootNamespace>Faithlife.Testing</RootNamespace>
    <Description>Faithlife.Testing.WebRequests class library.</Description>
    <PackageTags></PackageTags>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RewritePackageReadmeLinks>true</RewritePackageReadmeLinks>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Faithlife.Json" />
    <PackageReference Include="Faithlife.Reflection" />
    <PackageReference Include="Faithlife.WebRequests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Faithlife.Testing\Faithlife.Testing.csproj" />
  </ItemGroup>

</Project>
